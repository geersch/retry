{
  "name": "root",
  "private": true,
  "packageManager": "bun@1.3.14",
  "type": "module",
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "catalog": {
      "@arethetypeswrong/cli": "^0.18.2",
      "@commitlint/cli": "^21.0.2",
      "@commitlint/config-conventional": "^21.0.2",
      "@typescript/native-preview": "beta",
      "@vitest/coverage-v8": "^4.1.9",
      "husky": "^9.1.7",
      "is-ci": "^4.1.0",
      "oxlint": "^1.70.0",
      "oxfmt": "^0.55.0",
      "reflect-metadata": "^0.2.2",
      "rimraf": "^6.1.3",
      "rxjs": "^7.0.0",
      "turbo": "^2.9.18",
      "typescript": "npm:@typescript/typescript6@^6.0.0",
      "vitest": "^4.1.9"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/geersch/retry.git"
  },
  "author": "Christophe Geers",
  "license": "MIT",
  "scripts": {
    "build": "turbo build",
    "check-exports": "turbo check-exports",
    "check-types": "turbo check-types",
    "clean": "turbo clean",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "quality": "turbo run quality",
    "quality:fix": "turbo run quality:fix",
    "test": "turbo test",
    "postinstall": "is-ci || husky"
  },
  "bugs": {
    "url": "https://github.com/geersch/retry/issues"
  },
  "homepage": "https://github.com/geersch/retry#readme",
  "devDependencies": {
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "husky": "catalog:",
    "is-ci": "catalog:",
    "oxlint": "catalog:",
    "oxfmt": "catalog:",
    "turbo": "catalog:",
    "vitest": "catalog:"
  }
}
