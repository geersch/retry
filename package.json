{
  "name": "root",
  "workspaces": [
    "packages/*"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/geersch/retry.git"
  },
  "author": "Christophe Geers",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "FORCE_COLOR=true bun run --filter '*' build",
    "build:check": "FORCE_COLOR=true bun run --filter '*' build:check",
    "check-exports": "FORCE_COLOR=true bun run --filter '*' check-exports",
    "clean": "FORCE_COLOR=true bun run --filter '*' clean",
    "format": "FORCE_COLOR=true bun run --filter '*' format",
    "format:check": "FORCE_COLOR=true bun run --filter '*' format:check",
    "lint": "FORCE_COLOR=true bun run --filter '*' lint",
    "lint:check": "FORCE_COLOR=true bun run --filter '*' lint:check",
    "postinstall": "is-ci || husky"
  },
  "bugs": {
    "url": "https://github.com/geersch/retry/issues"
  },
  "homepage": "https://github.com/geersch/retry#readme",
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@vitest/coverage-v8": "^4.1.5",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "oxlint": "^1.62.0",
    "vitest": "^4.1.5"
  }
}
