{
  "name": "@geersch/nestjs-retry",
  "version": "1.1.0",
  "description": "NestJS interceptor to retry endpoints with configurable backoff strategies.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/geersch/retry.git"
  },
  "author": "Christophe Geers",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**/*",
    "lib/**/**"
  ],
  "scripts": {
    "build": "tsgo -b tsconfig.package.json",
    "check-exports": "attw --pack . --ignore-rules=cjs-resolves-to-esm",
    "check-types": "tsgo -b tsconfig.json",
    "clean": "rimraf dist coverage junit.xml tsconfig.package.tsbuildinfo",
    "test": "vitest run"
  },
  "keywords": [
    "exponential",
    "backoff",
    "jitter",
    "retry"
  ],
  "bugs": {
    "url": "https://github.com/geersch/retry/issues"
  },
  "homepage": "https://github.com/geersch/retry#readme",
  "dependencies": {
    "@geersch/retry": "workspace:^"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@geersch/retry": "workspace:^",
    "@geersch/typescript-config": "workspace:*",
    "@geersch/vitest-config": "workspace:*",
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/testing": "^11.1.19",
    "@types/supertest": "^7.2.0",
    "@typescript/native-preview": "catalog:",
    "reflect-metadata": "catalog:",
    "rimraf": "catalog:",
    "rxjs": "catalog:",
    "supertest": "^7.2.2",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@nestjs/common": "^9.0.0 || ^10.0.4 || ^11.0.0",
    "@nestjs/core": "^9.0.0 || ^10.0.4 || ^11.0.0",
    "reflect-metadata": "^0.1.12 || ^0.2.0"
  }
}
