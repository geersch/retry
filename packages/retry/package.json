{
  "name": "@geersch/retry",
  "version": "1.1.0",
  "description": "Backoff strategies to use when retrying a function after a given delay.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/geersch/retry.git"
  },
  "author": "Christophe Geers",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**/*",
    "lib/**/**"
  ],
  "scripts": {
    "build": "tsgo -b tsconfig.package.json",
    "check-exports": "attw --pack . --ignore-rules=cjs-resolves-to-esm",
    "check-types": "tsgo --noEmit",
    "clean": "rimraf dist coverage junit.xml tsconfig.package.tsbuildinfo",
    "test": "vitest run"
  },
  "keywords": [
    "exponential",
    "backoff",
    "jitter",
    "retry"
  ],
  "bugs": {
    "url": "https://github.com/geersch/retry/issues"
  },
  "homepage": "https://github.com/geersch/retry#readme",
  "dependencies": {
    "rxjs": "catalog:"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@geersch/typescript-config": "workspace:*",
    "@geersch/vitest-config": "workspace:*",
    "@typescript/native-preview": "catalog:",
    "reflect-metadata": "catalog:",
    "rimraf": "catalog:",
    "rxjs": "catalog:",
    "typescript": "catalog:"
  }
}
