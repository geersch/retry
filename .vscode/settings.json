{
  "js/ts.experimental.useTsgo": true,
  "oxc.enable.oxlint": true,
  "editor.codeActionsOnSave": [
    "source.fixAll.oxc"
  ],
  "editor.formatOnSave": true,
  "[javascript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[json]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "files.exclude": {
    "coverage": true,
    "**/*.tsbuildinfo": true,
    "**/junit.xml": true
  }
}